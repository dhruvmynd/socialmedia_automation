# ── Mastodon ──────────────────────────────────────────────────────────────────
MASTODON_ACCESS_TOKEN=your_mastodon_access_token
MASTODON_API_BASE_URL=https://mastodon.social   # change to your instance

# ── Instagram (Graph API via Facebook App) ────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_long_lived_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# ── Facebook (Graph API) ──────────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# ── LinkedIn (OAuth2) ─────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_ORGANIZATION_ID=your_org_id_optional   # leave blank for personal profile

# ── OpenAI (optional rewrite) ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o                             # or o3, gpt-4-turbo, etc.

# ── Spreadsheet ───────────────────────────────────────────────────────────────
SPREADSHEET_PATH=posts.xlsx                     # path to your spreadsheet file
